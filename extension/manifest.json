{
  "manifest_version": 3,
  "name": "AegisX AI Guardian",
  "version": "1.0.0",
  "description": "Autonomous AI digital twin for real-time cybersecurity.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["*://*/*", "http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
